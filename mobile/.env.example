# Firebase Client Configuration for Expo Mobile App
# Expo automatically injects variables prefixed with EXPO_PUBLIC_ into the JS bundle.

EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-auth-domain
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-storage-bucket
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id

# Backend API Base URL
# - Use http://10.0.2.2:3000/api for Android Emulator
# - Use http://localhost:3000/api for iOS Simulator / Web
# - Use http://<your-computer-ip>:3000/api for physical devices
EXPO_PUBLIC_API_URL=http://localhost:3000/api
